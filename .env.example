# TMDB API Key - Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Port (optional, defaults to 3000)
PORT=3000

# Secret Key - Alternative to SUPER_SECRET_PASS for adult section access
SECRET_KEY=your_secret_key_here

# Super Secret (Adult Content) Password
SUPER_SECRET_PASS=your_super_secret_password

# AdultDataLink API Key - Get from https://account.adultdatalink.com
ADULT_API_KEY=your_adult_api_key