{
  "name": "streamflix-android",
  "version": "1.0.0",
  "description": "StreamFlix Android App",
  "main": "index.js",
  "scripts": {
    "build": "echo 'No build needed for Capacitor web assets'",
    "cap:init": "npx cap init streamflix com.streamflix.app --web-dir www",
