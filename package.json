{
  "name": "streamflix-pro",
  "version": "2.0.0",
  "description": "StreamFlix Pro - Netflix-style streaming app",
  "main": "server/index.js",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "build": "cd client && npm install && npm run build",
    "start": "node server/index.js",
    "dev": "concurrently \"npm run start\" \"cd client && npm start\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^1.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}